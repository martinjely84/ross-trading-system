# ── Alpaca ────────────────────────────────────────────────────────────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true                 # true routes to the paper trading endpoint

# ── Telegram ──────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=                 # numeric chat id; only this id may issue commands

# ── Kill switch ───────────────────────────────────────────────────────
KILL=false                        # true halts all NEW entries (exits still managed)

# ── Strategy ──────────────────────────────────────────────────────────
MOMENTUM_PCT=0.03                 # require +3% over trailing 1h
VOLUME_MULT=2.0                   # last-1h vol > 2.0x trailing-24h avg hourly vol
MAX_EXTENSION_PCT=0.08            # skip if already +8% on the day (anti blow-off)
MAX_SPREAD_PCT=0.0015             # skip if (ask-bid)/mid >= 0.15%
MIN_HOURLY_VOLUME_USD=500000      # require >$500k trailing-1h USD volume
TP_PCT=0.04                       # take profit +4%
SL_PCT=0.02                       # stop loss -2%
MAX_HOLD_HOURS=4                  # time stop: exit after 4h regardless

# ── Risk ──────────────────────────────────────────────────────────────
POSITION_SIZE_PCT=0.10            # 10% of available cash per position
MAX_POSITIONS=3
MAX_DAILY_TRADES=5
REENTRY_COOLDOWN_HOURS=2          # block re-entry on a symbol for 2h after close
DAILY_LOSS_LIMIT_PCT=0.05         # halt new entries for the UTC day at -5% equity

# ── Backtest ──────────────────────────────────────────────────────────
FEE_PCT=0.0025                    # 0.25% per side
SLIPPAGE_PCT=0.001                # 0.1% per side

# ── Operational (optional overrides) ──────────────────────────────────
# WATCHLIST=BTC/USD,ETH/USD,SOL/USD
# LOOP_INTERVAL_SECONDS=60
# SCAN_INTERVAL_SECONDS=300
# DB_PATH=crypto_bot_state.db
# LOG_LEVEL=INFO
